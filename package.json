{
  "name": "pathfinder-assessmentform",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:reset-cache": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:fresh": "npm run dev:reset-cache && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:max-lines": "tsx scripts/quality/check-max-lines.ts",
    "check:secrets": "node scripts/check-secrets.cjs",
    "check:unused-exports": "node scripts/check-unused-exports.cjs --strict",
    "check:required-docs": "node scripts/check-required-docs.cjs",
    "check:env-example": "node scripts/check-env-example.cjs",
    "postdeploy:check": "node scripts/postdeploy-check.cjs",
    "doctor": "node scripts/doctor.cjs",
    "deploy:prod": "node scripts/deploy-prod.cjs",
    "test:unit": "node scripts/run-unit-tests.cjs",
    "test:integration:node": "node scripts/run-integration-tests.cjs",
    "test:integration": "firebase emulators:exec --project assessmentform-test --only firestore \"npm run test:integration:node\"",
    "test:java": "node scripts/run-java-tests.cjs",
    "test:regression": "tsx scripts/regression/run.ts",
    "test:e2e:smoke": "node scripts/run-smoke-tests.cjs",
    "backfill:lead-indexes": "tsx scripts/backfill/build-lead-indexes.ts",
    "ops:resume-scan:decide": "tsx scripts/ops/process-resume-scan-decision.ts",
    "ops:resume-scan:cleanup": "tsx scripts/ops/cleanup-expired-quarantine.ts",
    "ops:erase:lead": "tsx scripts/ops/erase-lead-artifacts.ts",
    "verify": "npm run typecheck && npm run lint && npm run check:max-lines && npm run check:secrets && npm run check:unused-exports && npm run check:required-docs && npm run check:env-example && npm run test:unit && npm run test:regression && npm run build",
    "verify:smoke": "npm run verify && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@upstash/redis": "^1.35.6",
    "firebase-admin": "^13.7.0",
    "next": "16.2.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@types/node": "^20.14.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.1.7",
    "firebase-tools": "^14.20.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.17",
    "ts-prune": "^0.10.3",
    "tsx": "^4.20.6",
    "typescript": "^5.5.4"
  },
  "overrides": {
    "node-forge": "^1.4.0",
    "fast-xml-parser": "^5.5.10",
    "brace-expansion": "^2.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}


