# Client
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Server
TURNSTILE_SECRET_KEY=your-turnstile-secret
TURNSTILE_EXPECTED_ACTION=assessment_submit
TURNSTILE_EXPECTED_HOSTNAMES=assessment-form.example.com

# Option A (recommended): full service account JSON string or absolute file path
FIREBASE_ADMIN_SDK_JSON=path-or-json

# Option B: split fields
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Optional canonical host override used by middleware redirect
APP_CANONICAL_HOST=assessment-form.example.com

# Optional distributed rate limiting (falls back to in-memory limiter when unset)
UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# Optional: trust proxy headers outside production
TRUST_PROXY_HEADERS=true
# Optional: trust Cloudflare cf-connecting-ip header (off by default)
TRUST_CLOUDFLARE_CONNECTING_IP=false

# Optional: keep broad legacy precheck fallbacks enabled until backfill is fully verified
ASSESSMENT_ENABLE_LEGACY_FALLBACKS=true

# Optional: emit indexed precheck mode logs in addition to fallback/degraded logs
ASSESSMENT_LOG_INDEXED_PRECHECKS=false

# Optional: quarantine retention window (days) for resume scan lifecycle
RESUME_QUARANTINE_RETENTION_DAYS=30

